{
  "name": "Linux Mint",
  "service": "qemu",
  "containerEnv": {
    "BOOT": "mint"
  },
  "forwardPorts": [8006],
  "portsAttributes": {
    "8006": {
      "label": "Web",
      "onAutoForward": "notify"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }, 
  "dockerComposeFile": "codespaces.yml",
  "initializeCommand": "tailscale up -ssh --hostname=tailnet-dev && docker system prune --all --force",
  "features": {
    "ghcr.io/tailscale/codespace/tailscale": {
      "version": "latest"
    }
  },
  "containerEnv": {
    "TAILSCALE_AUTHKEY": "${TAILSCALE_AUTHKEY}",
    "TAILNET_NAME": "${TAILNET_NAME}"
  }
}
