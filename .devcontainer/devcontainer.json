{
  "name": "Tailnet Podman",
  "dockerComposeFile": "codespaces.yml",
  "service": "qemu",
  "workspaceFolder": "/workspace",
  
  "features": {
    "ghcr.io/tailscale/codespace/tailscale": {
      "version": "latest"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },

  "postCreateCommand": "tailscale up --authkey=${TAILSCALE_AUTHKEY} --ssh --accept-dns=false --hostname=tailnet-dev"
}
