{
  "name": "Proxmox",
  "service": "qemu",
  "containerEnv": {
    "BOOT": "proxmox"
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "dockerComposeFile": "./codespaces.yml",
  "initializeCommand": [
    "docker system prune --all --force",  // Clean up old containers and networks
    "docker network create -d bridge --subnet=172.18.0.0/24 --gateway=172.18.0.1 zone1",
    "docker network create -d bridge --subnet=124.10.0.0/24 --gateway=124.10.0.1 zone2",
    "docker network connect zone1 qemu",
    "docker network connect zone2 qemu",
    "echo 'Network setup completed. IPv4 and IPv6 configured.'"
  ],
  "finalizeCommand": [
    "echo 'Finalizing setup...'", 
    "docker network inspect zone1",
    "docker network inspect zone2"
  ]
}
