{
  "name": "Tailnet Podman",
  "build": {
    "dockerfile": "../Containerfile",
    "context": "."
  },
  "runArgs": [
    "--device=/dev/net/tun"
  ],
  "features": {
    "ghcr.io/tailscale/codespace/tailscale": {
      "version": "latest"
    },
    "ghcr.io/devcontainers-extra/features/caddy:1": {},
    "ghcr.io/devcontainers-extra/features/podman-homebrew:1": {}
  },
  "postCreateCommand": "sudo tailscale up --ssh --hostname=tailnet-podman"
}