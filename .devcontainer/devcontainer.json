{
  "name": "Default",
  "service": "qemu",
  "containerEnv": {
    "BOOT": "proxmox"
  },
  "forwardPorts": [8006],
  "portsAttributes": {
    "8006": {
      "label": "Web",
      "onAutoForward": "notify"
    }
  },
  "runArgs": [
  "--network", "bridge",
  "--privileged",
  "--cap-add=NET_ADMIN"
],
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }, 
  "features": {
    "ghcr.io/tailscale/codespace/tailscale": {
      "version": "latest"
    }
  },
  "dockerComposeFile": "codespaces.yml",
  "initializeCommand": "export TAILSCALE_AUTHKEY=${TAILSCALE_AUTHKEY} && export TAILNET_NAME=${TAILNET_NAME} && docker system prune --all --force",
  "postCreateCommand": "tailscale up --ssh --hostname=tailnet-dev"
}
